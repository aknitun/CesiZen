{% extends 'base.html.twig' %}

{% block title %}Modifier mon compte – CesiZen{% endblock %}

{% block body %}
    <section style="max-width: 640px; margin: 0 auto;">
        <h1 style="margin: 0 0 1.25rem;">Mon compte</h1>

        {# Messages de succès #}
        {% for message in app.flashes('success') %}
            <p style="color: green; margin: 0 0 .75rem;">{{ message }}</p>
        {% endfor %}

        <div style="
            background: var(--white);
            border-radius: 1rem;
            padding: 1.5rem 1.75rem;
            box-shadow:
                0 10px 24px rgba(15, 23, 42, 0.10),
                0 0 0 1px rgba(148, 163, 184, 0.25);
        ">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem;">
                <div class="user-avatar">
                    {{ app.user.prenom|first|upper ~ app.user.nom|first|upper }}
                </div>
                <div>
                    <h2 style="margin: 0;">{{ app.user.prenom }} {{ app.user.nom }}</h2>
                    <p style="margin: .1rem 0 0; font-size: .9rem; color: var(--text-muted);">
                        {{ app.user.email }}
                    </p>
                </div>
            </div>

            {{ form_start(userForm) }}
            <div style="border-top: 1px solid rgba(226, 232, 240, 0.9); padding-top: 1rem; display: flex; flex-direction: column; gap: .6rem;">
                {{ form_row(userForm.prenom) }}
                {{ form_row(userForm.nom) }}
                {{ form_row(userForm.email) }}
            </div>

            <div style="border-top: 1px solid rgba(226, 232, 240, 0.9); padding-top: 1rem; margin-top: 1rem; display: flex; flex-direction: column; gap: .6rem;">
                <h3 style="margin: 0 0 .5rem; font-size: 1rem;">Modifier mon mot de passe</h3>
                {{ form_row(userForm.plainPassword.first) }}
                {{ form_row(userForm.plainPassword.second) }}
            </div>

            <div style="margin-top: 1.4rem; display: flex; justify-content: space-between; gap: .75rem;">
                <a href="{{ path('app_user_show') }}" class="btn btn-ghost">
                    Annuler
                </a>
                <button type="submit" class="btn btn-primary">
                    Mettre à jour
                </button>
            </div>
            {{ form_end(userForm) }}
        </div>
    </section>
{% endblock %}