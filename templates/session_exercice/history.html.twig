{% extends 'base.html.twig' %}

{% block title %}Mon historique de respiration – CesiZen{% endblock %}

{% block body %}
    <section style="max-width: 960px; margin: 0 auto;">
        <h1 style="margin: 0 0 1.25rem;">Mon historique de respiration</h1>

        <p style="margin: 0 0 1.5rem; font-size: .95rem; color: var(--text-muted);">
            Retrouvez ici vos séances d’exercices de respiration.
            Les séances <strong>terminées</strong> sont affichées en vert, les séances
            <strong>interrompues</strong> en gris.
        </p>

        {% if sessions is empty %}
            <p style="color: var(--text-muted); font-size: .95rem;">
                Vous n’avez pas encore de séances enregistrées.
                Lancez un exercice de respiration pour commencer à remplir votre historique.
            </p>
        {% else %}
            {% set currentPage = page %}
            {% set currentLimit = limit %}
            {% set currentSort = sort %}
            {% set currentDirection = direction %}
            {% set toggledDirection = currentDirection == 'asc' ? 'desc' : 'asc' %}

            <div style="
                border-radius: .9rem;
                border: 1px solid rgba(148, 163, 184, 0.6);
                overflow: hidden;
                background: white;
                box-shadow:
                    0 10px 25px rgba(15, 23, 42, 0.06),
                    0 0 0 1px rgba(148, 163, 184, 0.18);
            ">
                <table style="width: 100%; border-collapse: collapse; font-size: .9rem;">
                    <thead>
                    <tr style="background: linear-gradient(to right, #eff6ff, #f1f5f9);">
                        {# COLONNE DATE (triable) #}
                        {% set isActive = currentSort == 'date' %}
                        {% set dirForCol = isActive ? toggledDirection : 'desc' %}
                        <th style="padding: .7rem .9rem; text-align: left; font-weight: 600; color: #0f172a; font-size: .85rem;">
                            <a href="{{ path('app_session_exercice_history', {
                                page: 1,
                                limit: currentLimit,
                                sort: 'date',
                                direction: dirForCol
                            }) }}"
                               style="display:inline-flex; align-items:center; gap:.25rem; color: inherit; text-decoration:none;">
                                Date
                                {% if isActive %}
                                    <span style="font-size:.75rem; color:#4b5563;">
                                        {{ currentDirection == 'asc' ? '▲' : '▼' }}
                                    </span>
                                {% endif %}
                            </a>
                        </th>

                        {# COLONNE EXERCICE (triable) #}
                        {% set isActive = currentSort == 'exercice' %}
                        {% set dirForCol = isActive ? toggledDirection : 'asc' %}
                        <th style="padding: .7rem .9rem; text-align: left; font-weight: 600; color: #0f172a; font-size: .85rem;">
                            <a href="{{ path('app_session_exercice_history', {
                                page: 1,
                                limit: currentLimit,
                                sort: 'exercice',
                                direction: dirForCol
                            }) }}"
                               style="display:inline-flex; align-items:center; gap:.25rem; color: inherit; text-decoration:none;">
                                Exercice
                                {% if isActive %}
                                    <span style="font-size:.75rem; color:#4b5563;">
                                        {{ currentDirection == 'asc' ? '▲' : '▼' }}
                                    </span>
                                {% endif %}
                            </a>
                        </th>

                        {# COLONNE RYTHME (NON triable) #}
                        <th style="padding: .7rem .9rem; text-align: left; font-weight: 600; color: #0f172a; font-size: .85rem;">
                            Rythme
                        </th>

                        {# COLONNE STATUT (triable) #}
                        {% set isActive = currentSort == 'statut' %}
                        {% set dirForCol = isActive ? toggledDirection : 'asc' %}
                        <th style="padding: .7rem .9rem; text-align: left; font-weight: 600; color: #0f172a; font-size: .85rem;">
                            <a href="{{ path('app_session_exercice_history', {
                                page: 1,
                                limit: currentLimit,
                                sort: 'statut',
                                direction: dirForCol
                            }) }}"
                               style="display:inline-flex; align-items:center; gap:.25rem; color: inherit; text-decoration:none;">
                                Statut
                                {% if isActive %}
                                    <span style="font-size:.75rem; color:#4b5563;">
                                        {{ currentDirection == 'asc' ? '▲' : '▼' }}
                                    </span>
                                {% endif %}
                            </a>
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for session in sessions %}
                        {% set exercice = session.exerciceRespiration %}
                        {% set isTerminee = session.statut == 'terminee' %}

                        <tr style="
                                border-top: 1px solid rgba(226, 232, 240, 0.95);
                        {% if loop.index is odd %}background: #f9fafb;{% endif %}
                                ">
                            <td style="padding: .6rem .9rem; white-space: nowrap; color: #0f172a;">
                                <div style="font-weight: 500;">
                                    {{ session.dateDebut ? session.dateDebut|date('d/m/Y') : '–' }}
                                </div>
                                <div style="font-size: .78rem; color: #6b7280;">
                                    {{ session.dateDebut ? session.dateDebut|date('H:i') : '' }}
                                </div>
                            </td>

                            <td style="padding: .6rem .9rem;">
                                {% if exercice %}
                                    <div style="font-weight: 600; color: #111827;">{{ exercice.nom }}</div>
                                {% else %}
                                    <span style="color: var(--text-muted); font-style: italic;">Exercice inexistant</span>
                                {% endif %}
                            </td>

                            <td style="padding: .6rem .9rem;">
                                {% if exercice %}
                                    <div style="font-size: .82rem; color: #374151;">
                                        <span style="font-weight: 500;">{{ exercice.dureeInspiration }}s</span> insp. –
                                        <span style="font-weight: 500;">{{ exercice.dureeApnee }}s</span> apnée –
                                        <span style="font-weight: 500;">{{ exercice.dureeExpiration }}s</span> exp.
                                    </div>
                                {% else %}
                                    <span style="color: #9ca3af;">–</span>
                                {% endif %}
                            </td>

                            <td style="padding: .6rem .9rem;">
                                {% if isTerminee %}
                                    <span style="
                                        display:inline-flex;
                                        align-items:center;
                                        gap:.35rem;
                                        padding:.18rem .5rem;
                                        border-radius: 999px;
                                        background: rgba(22, 163, 74, 0.09);
                                        color: #15803d;
                                        font-size: .8rem;
                                        font-weight: 600;
                                        border: 1px solid rgba(34, 197, 94, 0.35);
                                    ">
                                        <span style="
                                            width: 7px;
                                            height: 7px;
                                            border-radius: 999px;
                                            background:#22c55e;
                                        "></span>
                                        Terminée
                                    </span>
                                {% else %}
                                    <span style="
                                        display:inline-flex;
                                        align-items:center;
                                        gap:.35rem;
                                        padding:.18rem .5rem;
                                        border-radius: 999px;
                                        background: rgba(148, 163, 184, 0.12);
                                        color: #4b5563;
                                        font-size: .8rem;
                                        font-weight: 500;
                                        border: 1px solid rgba(148, 163, 184, 0.4);
                                    ">
                                        <span style="
                                            width: 7px;
                                            height: 7px;
                                            border-radius: 999px;
                                            background:#9ca3af;
                                        "></span>
                                        Interrompue
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {# --- Pagination + sélecteur de lignes --- #}
            <div style="
                margin-top: .85rem;
                display: flex;
                flex-wrap: wrap;
                justify-content: space-between;
                align-items: center;
                gap: .75rem;
                font-size: .85rem;
                color: #4b5563;
            ">
                <div>
                    Afficher
                    <form method="get" action="{{ path('app_session_exercice_history') }}"
                          style="display:inline-block; margin: 0 .25rem;">
                        <select name="limit" onchange="this.form.submit()"
                                style="
                                    padding: .18rem .45rem;
                                    border-radius: .4rem;
                                    border: 1px solid rgba(148, 163, 184, 0.9);
                                    font-size: .82rem;
                                    background: white;
                                ">
                            {% for l in allowed_limits %}
                                <option value="{{ l }}" {% if limit == l %}selected{% endif %}>
                                    {{ l }}
                                </option>
                            {% endfor %}
                            <option value="-1" {% if limit == -1 %}selected{% endif %}>
                                Tout
                            </option>
                        </select>

                        <input type="hidden" name="page" value="1">
                        <input type="hidden" name="sort" value="{{ currentSort }}">
                        <input type="hidden" name="direction" value="{{ currentDirection }}">
                    </form>
                    lignes par page
                </div>

                <div style="display:flex; align-items:center; gap:.35rem;">
                    {% if total_pages > 1 %}
                        <nav aria-label="Pagination" style="display:flex; align-items:center; gap:.25rem;">
                            {# Précédent #}
                            {% if page > 1 %}
                                <a href="{{ path('app_session_exercice_history', {
                                    page: page - 1,
                                    limit: currentLimit,
                                    sort: currentSort,
                                    direction: currentDirection
                                }) }}"
                                   style="
                                       padding: .18rem .45rem;
                                       border-radius: .4rem;
                                       border: 1px solid rgba(148,163,184,0.7);
                                       background: white;
                                       color:#374151;
                                       text-decoration:none;
                                       font-size:.8rem;
                                   ">
                                    ‹
                                </a>
                            {% else %}
                                <span style="
                                   padding: .18rem .45rem;
                                   border-radius: .4rem;
                                   border: 1px solid rgba(209,213,219,0.8);
                                   color:#9ca3af;
                                   font-size:.8rem;
                                ">‹</span>
                            {% endif %}

                            {# Numéros de pages #}
                            {% for p in 1..total_pages %}
                                {% if p == page %}
                                    <span style="
                                        padding: .18rem .5rem;
                                        border-radius: .4rem;
                                        background: #2563eb;
                                        color: white;
                                        font-size: .8rem;
                                        font-weight: 600;
                                    ">{{ p }}</span>
                                {% else %}
                                    <a href="{{ path('app_session_exercice_history', {
                                        page: p,
                                        limit: currentLimit,
                                        sort: currentSort,
                                        direction: currentDirection
                                    }) }}"
                                       style="
                                           padding: .18rem .5rem;
                                           border-radius: .4rem;
                                           border: 1px solid rgba(148,163,184,0.7);
                                           background: white;
                                           color:#374151;
                                           text-decoration:none;
                                           font-size:.8rem;
                                       ">
                                        {{ p }}
                                    </a>
                                {% endif %}
                            {% endfor %}

                            {# Suivant #}
                            {% if page < total_pages %}
                                <a href="{{ path('app_session_exercice_history', {
                                    page: page + 1,
                                    limit: currentLimit,
                                    sort: currentSort,
                                    direction: currentDirection
                                }) }}"
                                   style="
                                       padding: .18rem .45rem;
                                       border-radius: .4rem;
                                       border: 1px solid rgba(148,163,184,0.7);
                                       background: white;
                                       color:#374151;
                                       text-decoration:none;
                                       font-size:.8rem;
                                   ">
                                    ›
                                </a>
                            {% else %}
                                <span style="
                                   padding: .18rem .45rem;
                                   border-radius: .4rem;
                                   border: 1px solid rgba(209,213,219,0.8);
                                   color:#9ca3af;
                                   font-size:.8rem;
                                ">›</span>
                            {% endif %}
                        </nav>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </section>
{% endblock %}